st\", \"Dublin\", \"London\", \"Lyon\",\n","    \"Munich\", \"Oslo\", \"Paris\", \"The Hague\", \"Venice\"\n","]\n","\n","# Columns to keep for the Silver Reviews table\n","# Adjust these names if your files use different naming conventions (e.g., 'review_id' instead of 'id')\n","COLS_TO_KEEP_REVIEWS = [\n","    'listing_id',  # To link to the Listings table\n","    'id',          # The unique review ID\n","    'date',\n","    'reviewer_id',\n","    'reviewer_name',\n","    'comments',    # The text of the review\n","]\n","\n","# Authenticate and get GCS client (assuming you have performed 'auth.authenticate_user()' in Cell 1)\n","# storage_client = storage.Client()\n","# You should run the storage client initialization here if not done in a previous cell.\n","\n","review_df_list = []\n","print(f\"Searching for review files in gs://{BUCKET_NAME}/{SOURCE_PREFIX_REVIEWS}...\")\n","\n","# 1. & 2. Iterate, Combine, and Standardize\n","for city_name in CITIES:\n","    # Assuming review files are named like 'amsterdam_reviews.csv'\n","    file_name = f\"{city_name}_reviews.csv\"\n","    gcs_path = f'gs://{BUCKET_NAME}/{SOURCE_PREFIX_REVIEWS}{file_name}'\n","\n","    try:\n","        # Read the CSV\n","        df = pd.read_csv(gcs_path, low_memory=False)\n","\n","        # 3. Column Selection\n","        actual_cols_to_keep = [col for col in COLS_TO_KEEP_REVIEWS if col in df.columns]\n","        df = df[actual_cols_to_keep].copy()\n","\n","        # 2. Add City\n","        df.insert(1, 'city', city_name)\n","\n","        review_df_list.append(df)\n","        print(f\"--> Processed reviews for: {city_name}\")\n","\n","    except Exception as e:\n","        # If the file is not found (like the issue with pricing files), it will skip it.\n","        print(f\"❌ Error processing {file_name}. Skipping. Error: {e}\")\n","\n","# Combine all city DataFrames\n","if review_df_list:\n","    main_reviews_df = pd.concat(review_df_list, ignore_index=True)\n","    print(f\"\\n✅ All cities combined. Total Reviews: {len(main_reviews_df)}\")\n","\n","    # 4. Data Type Refinement\n","    # Convert Date column\n","    if 'date' in main_reviews_df.columns:\n","        main_reviews_df['date'] = pd.to_datetime(main_reviews_df['date'], errors='coerce')\n","\n","    # Convert ID columns to 'Int64' (Nullable Integer)\n","    id_cols = ['id', 'listing_id', 'reviewer_id']\n","    for col in id_cols:\n","        if col in main_reviews_df.columns:\n","            # Using errors='coerce' turns non-numeric values into NaN,\n","            # which is then handled by the 'Int64' nullable type.\n","            main_reviews_df[col] = pd.to_numeric(main_reviews_df[col], errors='coerce').astype('Int64')\n","\n","    print(\"\\n--- New Review Data Types ---\")\n","    main_reviews_df.info()\n","    # 5. Save to Silver Layer\n","    print(f\"\\nSaving combined reviews to: {SILVER_REVIEWS_PATH}...\")\n","    main_reviews_df.to_parquet(SILVER_REVIEWS_PATH, index=False)\n","    print(\"\\n✅ Combined Reviews Table loaded to Silver Layer.\")\n","\n","    # Display a sample of the final data\n","    print(\"\\nSample of Cleaned Reviews Data:\")\n","    display(main_reviews_df.head())\n","else:\n","    print(\"\\n⚠️ No review files were successfully processed. Please check file names and paths.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":921},"id":"bLykYzWbunP8","executionInfo":{"status":"ok","timestamp":1765416992301,"user_tz":-60,"elapsed":5182675,"user":{"displayName":"Nadi","userId":"17104900073799503001"}},"outputId":"b51d11a5-7dee-4cb1-94fd-947ffdc95830"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Searching for review files in gs://dw-airbnb-data-lake/bronze_layer/raw_reviews/...\n","--> Processed reviews for: Amsterdam\n","--> Processed reviews for: Athens\n","--> Processed reviews for: Barcelona\n","--> Processed reviews for: Berlin\n","--> Processed reviews for: Bristol\n","--> Processed reviews for: Bru