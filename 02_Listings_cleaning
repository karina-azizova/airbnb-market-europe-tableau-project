ter Outliers\n","            df = df[ (df['price'] <= PRICE_CAP) & (df['price'] >= PRICE_FLOOR) ]\n","\n","            df_list.append(df)\n","            print(f\"--> Processed: {city_name}\")\n","\n","        except Exception as e:\n","            print(f\"❌ Error processing {file_name}: {e}\")\n","\n","# Combine\n","if df_list:\n","    main_df = pd.concat(df_list, ignore_index=True)\n","    print(f\"\\n✅ All cities combined. Total Rows: {len(main_df)}\")\n","\n","    # Check Budapest specifically to verify the fix\n","    display(main_df[main_df['city'] == 'Budapest'][['price', 'city']].head())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":578},"id":"l8fYga72izp9","executionInfo":{"status":"ok","timestamp":1765375226976,"user_tz":-60,"elapsed":112516,"user":{"displayName":"Aurora Ruci","userId":"16341822791203429220"}},"outputId":"3680c61e-92ae-4ea2-acb0-7bb2b6533274"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Searching for files in gs://dw-airbnb-data-lake/bronze_layer/raw_listings/...\n","--> Processed: Amsterdam\n","--> Processed: Athens\n","--> Processed: Barcelona\n","--> Processed: Berlin\n","  💱 Converted Bristol prices (Rate: 1.2)\n","--> Processed: Bristol\n","--> Processed: Brussels\n","  💱 Converted Budapest prices (Rate: 0.0025)\n","--> Processed: Budapest\n","--> Processed: Dublin\n","  💱 Converted London prices (Rate: 1.2)\n","--> Processed: London\n","--> Processed: Lyon\n","--> Processed: Munich\n","  💱 Converted Oslo prices (Rate: 0.085)\n","--> Processed: Oslo\n","--> Processed: Paris\n","--> Processed: The Hague\n","--> Processed: Venice\n","\n","✅ All cities combined. Total Rows: 158198\n"]},{"output_type":"display_data","data":{"text/plain":["          price      city\n","52495   61.5500  Budapest\n","52496   59.7025  Budapest\n","52497  245.9925  Budapest\n","52498   57.5175  Budapest\n","52499   58.5675  Budapest"],"text/html":["\n","  <div id=\"df-cc813640-6a6c-4dba-8f00-eec3e7