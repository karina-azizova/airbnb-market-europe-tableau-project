V already exists locally: {local_filename_csv}\")\n","            return True\n","\n","    except Exception as e:\n","        print(f\"  -> ❌ ERROR during download/unzip: {e}\")\n","        return False\n","\n","\n","def scrape_and_process_all():\n","    \"\"\"Handles web scraping and calls the local downloader for all target cities.\"\"\"\n","    print(f\"Fetching data page: {DATA_PAGE_URL}...\")\n","    try:\n","        page = requests.get(DATA_PAGE_URL)\n","        page.raise_for_status()\n","    except requests.exceptions.RequestException as e:\n","        print(f\"❌ Error fetching page: {e}\")\n","        return\n","\n","    soup = BeautifulSoup(page.content, \"html.parser\")\n","    files_processed = 0\n","\n","    for table in soup.find_all(\"table\"):\n","        for row in table.find_all(\"tr\"):\n","            cells = row.find_all(\"td\")\n","            if not cells:\n","                continue\n","\n","            location_name_raw = cells[0].get_text().strip()\n","            city_found = [target for target in TARGET_LOCATIONS if target in location_name_raw]\n","\n","            if city_found:\n","                location_name = city_found[0]\n","\n","                link_found = False\n","                for link in row.find_all(\"a\"):\n","                    href = link.get(\"href\")\n","\n","                    if href and href.endswith(TARGET_FILE_TYPE):\n","                        link_found = True\n","                        print(f\"\\nProcessing {location_name}...\")\n","\n","                        if download_and_process_file(href, location_name):\n","                            files_processed += 1\n","\n","                        break\n","\n","                if not link_found:\n","                    print(f\"\\n⚠️ Found {location_name}, but no '{TARGET_FILE_TYPE}' link was found in its row.\")\n","\n","    print(f\"\\n--- Colab Bronze Layer Population Complete ---\")\n","    print(f\"Total files downloaded: {files_processed}\")\n","    return files_processed\n","\n","\n","if __name__ == \"__main__\":\n","    setup_local_directory()\n","    scrape_and_process_all()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"mzNi32czUJBD","executionInfo":{"status":"ok","timestamp":1765207273753,"user_tz":-60,"elapsed":58745,"user":{"displayName":"Nadi","userId":"17104900073799503001"}},"outputId":"e37e9c80-479b-4099-9eb9-ee27c8ccd80a"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Fetching data page: http://insideairbnb.com/get-the-data.html...\n","\n","⚠️ Found Amsterdam, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Amsterdam, but no 'reviews.csv.gz' link was found in its row.\n","\n","Processing Amsterdam...\n","  -> ⬇️ Starting download and unzip...\n","  -> ✅ Saved unzipped CSV locally: BRONZE_RAW_CHECKPOINT/Amsterdam_reviews.csv\n","\n","⚠️ Found Amsterdam, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Amsterdam, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Amsterdam, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Amsterdam, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Athens, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Athens, but no 'reviews.csv.gz' link was found in its row.\n","\n","Processing Athens...\n","  -> ⬇️ Starting download and unzip...\n","  -> ✅ Saved unzipped CSV locally: BRONZE_RAW_CHECKPOINT/Athens_reviews.csv\n","\n","⚠️ Found Athens, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Athens, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Athens, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Athens, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Barcelona, but no 'reviews.csv.gz' link was found in its row.\n","\n","⚠️ Found Barcelona, but no 'reviews.csv.gz' link was found in its row.\n","\n","Processing Barcelo